# HotelZippo environment template — see specs/13-environment.md
# Copy to .env.local and fill in values. NEVER commit .env.local (it is git-ignored).
# Only NEXT_PUBLIC_* are exposed to the browser; everything else is server-side only.

# --- Anthropic (server-side only) ---
ANTHROPIC_API_KEY=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-side only — never exposed to client

# --- Apify (server-side only) ---
APIFY_API_TOKEN=
APIFY_TRIPADVISOR_REVIEWS_ACTOR_ID=   # Phase 6 — TripAdvisor Reviews scraper
APIFY_GOOGLE_REVIEWS_ACTOR_ID=        # Phase 6 — Google Maps Reviews scraper
APIFY_TRIPADVISOR_SEARCH_ACTOR_ID=    # Phase 1 — TripAdvisor Hotel Search (curation); confirm exact name vs 12a
APIFY_SEARCH_MAX_RESULTS=50           # curation: top-N hotels per destination search (default 50)
APIFY_REVIEWS_MAX_RESULTS=600         # reviews: per-source over-fetch cap (format.ts re-filters to 12mo + caps 150/100/250)

# --- RouteStack (server-side only, Phase 7) ---
ROUTESTACK_API_KEY=               # partner API key (public identifier) — used in the HMAC token exchange
ROUTESTACK_API_SECRET=            # partner secret — signs the HMAC (apiKey:timestamp:nonce); NEVER exposed to client
ROUTESTACK_API_URL=               # HTTP base URL — sandbox: https://evolvemcp.routestack.ai

# --- Google OAuth via Supabase Auth (Phase 4) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Places (server-side only, Phase 1 curation) ---
GOOGLE_PLACES_API_KEY=            # Text Search (New), ID-only field mask — resolves curated hotels → google_place_id. Free 10k/mo SKU. Separate from the OAuth creds above.

# --- Observability: OTEL → Dash0 (server-side only) ---
DASH0_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Pipeline worker ---
PIPELINE_POLL_MS=5000            # review-intelligence worker poll interval, ms (scripts/pipeline/run-worker.ts; default 5000)

# --- Local dev only (NEVER set in production) ---
# Set to "true" in .env.local to enable the email/password "Dev sign-in" on the landing page,
# so you can reach the Google-gated /chat without OAuth. Pair with `npm run dev:user` (seeds a
# local dev user). Production auth stays Google-only; leave this UNSET in any real deployment.
NEXT_PUBLIC_ENABLE_DEV_LOGIN=

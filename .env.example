# HotelZippo environment template — see specs/13-environment.md
# Copy to .env.local and fill in values. NEVER commit .env.local (it is git-ignored).
# Only NEXT_PUBLIC_* are exposed to the browser; everything else is server-side only.

# --- Anthropic (server-side only) ---
ANTHROPIC_API_KEY=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-side only — never exposed to client

# --- Apify (server-side only) ---
APIFY_API_TOKEN=
APIFY_TRIPADVISOR_REVIEWS_ACTOR_ID=   # Phase 6 — TripAdvisor Reviews scraper
APIFY_GOOGLE_REVIEWS_ACTOR_ID=        # Phase 6 — Google Maps Reviews scraper
APIFY_TRIPADVISOR_SEARCH_ACTOR_ID=    # Phase 1 — TripAdvisor Hotel Search (curation); confirm exact name vs 12a
APIFY_SEARCH_POOL_SIZE=500            # curation: how many hotels to FETCH from the actor per destination (the large pool to rank from; default 500)
APIFY_SEARCH_MAX_RESULTS=50           # curation: top-N to KEEP after selection (prefer 4&5-star by Traveller Ranking, backfill if <N; default 50)
APIFY_REVIEWS_MAX_RESULTS=600         # reviews: per-source over-fetch cap (format.ts re-filters to 12mo + caps 150/100/250)

# --- RouteStack (server-side only, Phase 7) ---
ROUTESTACK_API_KEY=               # partner API key (public identifier) — used in the HMAC token exchange
ROUTESTACK_API_SECRET=            # partner secret — signs the HMAC (apiKey:timestamp:nonce); NEVER exposed to client
ROUTESTACK_API_URL=               # HTTP base URL — sandbox: https://evolvemcp.routestack.ai
ROUTESTACK_DEBUG_PAYLOADS=        # =1 → persist REDACTED RouteStack request/response to raw_routestack_payloads (debug; off by default)
ROUTESTACK_WEBHOOK_SECRET=        # shared secret = RouteStack dashboard "Webhook access key"; verifies /api/webhooks/routestack (10d). Unset → verification skipped (dev/sandbox)
ROUTESTACK_MOCK=                  # =1 → booking AND preview-runtime-seed use the MOCK RouteStack transport for a production-showable demo (10e). Server-only (NOT NEXT_PUBLIC_). Off/unset → live RouteStack. Flip to live = unset + redeploy
DEBUG_BOOKING=                    # =1 → emit step-by-step timing logs (recommendation assemble + booking rates) to stdout/Vercel Runtime Logs to diagnose which step hangs on a 60s timeout. Server-only, off by default

# --- Google OAuth via Supabase Auth (Phase 4) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Places (server-side only, Phase 1 curation) ---
GOOGLE_PLACES_API_KEY=            # Text Search (New), ID-only field mask — resolves curated hotels → google_place_id. Free 10k/mo SKU. Separate from the OAuth creds above.

# --- Observability: OTEL → Dash0 (server-side only) ---
# Set BOTH to export traces (web app + pipeline worker). With the endpoint unset, OTEL no-ops
# gracefully (local dev). DASH0_API_KEY is auto-mapped to the OTLP Authorization: Bearer header
# (lib/otel/dash0-headers.ts) — you do NOT need to set OTEL_EXPORTER_OTLP_HEADERS yourself. Use the
# Dash0 ingress BASE URL for OTEL_EXPORTER_OTLP_ENDPOINT (e.g. https://ingress.<region>.dash0.com —
# the exporter appends /v1/traces). DASH0_DATASET (optional) selects the Dash0 dataset via the
# Dash0-Dataset header (e.g. "dev"); Dash0 routes to "default" when unset.
DASH0_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=
DASH0_DATASET=
# Optional overrides (advanced): if you set OTEL_EXPORTER_OTLP_HEADERS yourself it WINS over the
# DASH0_API_KEY auto-mapping. Protocol defaults to http/protobuf via @vercel/otel.
# OTEL_EXPORTER_OTLP_HEADERS=
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# --- Pipeline worker ---
PIPELINE_POLL_MS=5000            # review-intelligence worker poll interval, ms (scripts/pipeline/run-worker.ts; default 5000)
PIPELINE_REFRESH=               # =1 forces a destination run to RE-synthesise EVERY hotel. Default (unset): a destination run processes ONLY hotels missing intelligence (never-done + failed) — so re-running to finish a partial destination never re-scrapes/re-bills already-completed hotels.

# --- Local dev only (NEVER set in production) ---
# Set to "true" in .env.local to enable the email/password "Dev sign-in" on the landing page,
# so you can reach the Google-gated /chat without OAuth. Pair with `npm run dev:user` (seeds a
# local dev user). Production auth stays Google-only; leave this UNSET in any real deployment.
NEXT_PUBLIC_ENABLE_DEV_LOGIN=

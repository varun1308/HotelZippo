# E2E environment (specs/15a-e2e-test-strategy.md) — COMMITTED, contains NO secrets.
#
# These are the WELL-KNOWN, PUBLIC Supabase CLI local-demo keys (iss: supabase-demo).
# They are identical on every local Supabase install and are ONLY valid against
# 127.0.0.1 — they grant nothing on any real project. Safe to commit; do NOT add any
# real ANTHROPIC / APIFY / ROUTESTACK / GOOGLE secret here. The agent + booking
# providers are STUBBED in E2E (NEXT_PUBLIC_E2E=1), so no real keys are ever needed.
#
# Used by: playwright.config.ts (webServer) + `next build` for E2E (so NEXT_PUBLIC_*
# flags bake in) + the CI e2e job. Pair with `npm run dev:db` (seed) + `npm run dev:user`.

# --- Local Supabase (CLI demo keys — public, localhost-only) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# --- E2E stub + dev-login flags (the whole point: no live providers, deterministic auth) ---
NEXT_PUBLIC_E2E=1
NEXT_PUBLIC_ENABLE_DEV_LOGIN=true

# Port the E2E server runs on (kept off the default 3000 so a running `next dev` doesn't clash).
E2E_PORT=3100

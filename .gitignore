# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Next.js
/.next/
/out/
next-env.d.ts

# TypeScript build info
*.tsbuildinfo

# Production build
/build
/dist

# Environment — never commit secrets (see specs/13-environment.md)
.env
.env.local
.env*.local
.env.development.local
.env.test.local
.env.production.local
.env.prod-curation
# .env.prod-curation holds PROD Supabase URL/key + curation creds for the prod data load — NEVER commit
# .env.example IS committed (template only, no values)
# .env.e2e IS committed (specs/15a) — only public localhost-only Supabase demo keys + E2E flags, no secrets

# Testing
/coverage
/playwright-report/
/playwright/.cache/
/test-results/

# Dev-only cached Apify actor output (banked once, replayed for free — never re-spend credits).
scripts/dev/.cache/

# Supabase local
.branches
.temp
supabase/.temp/
# Local-dev demo seed — generated by `npm run dev:gen-seed` (NOT committed, so CI's
# `supabase start` runs against a pristine DB; integration tests assume empty tables).
supabase/seed.sql

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db


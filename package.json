{
  "name": "hotelzippo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --selectProjects jsdom",
    "test:integration": "jest --selectProjects integration",
    "pipeline:worker": "tsx --env-file=.env.local scripts/pipeline/run-worker.ts",
    "booking:capture": "tsx --env-file=.env.local scripts/booking/capture-rates.ts",
    "dev:user": "tsx --env-file=.env.local scripts/dev/seed-dev-user.ts",
    "dev:gen-seed": "tsx scripts/dev/gen-seed-sql.ts",
    "dev:db": "npm run dev:gen-seed && supabase db reset"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@anthropic-ai/sdk": "^0.100.1",
    "@opentelemetry/api": "^1.9.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "@vercel/otel": "^1.10.0",
    "ai": "^6.0.197",
    "lucide-react": "^1.17.0",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.22.4",
    "typescript": "^5.6.2"
  }
}
